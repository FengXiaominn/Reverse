// 请替换成你的真实域名（必须 HTTPS，且已在小程序后台配置合法域名）
const TEST_API_BASE_URL = 'https://mp-api.bingzai.cn'
const PROD_API_BASE_URL = 'https://mp-api.bingzai.cn'
const DEV_API_BASE_URL = 'https://mp-api.bingzai.cn'

function trimTrailingSlash(url : string) : string {
	if (url.endsWith('/')) {
		return url.substring(0, url.length - 1)
	}
	return url
}

function getMiniProgramEnvVersion() : string {
	// 小程序环境：develop(开发版) / trial(体验版) / release(正式版)
	// #ifdef MP-WEIXIN
	const info : any = wx.getAccountInfoSync()
	if (info != null && info.miniProgram != null && info.miniProgram.envVersion != null) {
		return info.miniProgram.envVersion
	}
	// #endif
	return 'develop'
}

export function getApiBaseUrl() : string {
	const envVersion = getMiniProgramEnvVersion()
	if (envVersion == 'develop') {
		return trimTrailingSlash(DEV_API_BASE_URL)
	}
	if (envVersion == 'release') {
		return trimTrailingSlash(PROD_API_BASE_URL)
	}
	return trimTrailingSlash(TEST_API_BASE_URL)
}

function asList(raw : any) : Array<any> {
	if (raw == null) {
		return []
	}
	if (raw.data != null && raw.data.length != null) {
		return raw.data
	}
	if (raw.length != null) {
		return raw
	}
	return []
}

function parseError(err : any) : string {
	if (err == null) {
		return '请求失败'
	}
	if (err.errMsg != null && err.errMsg.length > 0) {
		return err.errMsg
	}
	return '请求失败'
}

function withUrl(err : any, url : string) : string {
	return parseError(err) + ' | ' + url
}

export function getReceivedInvites(
	onSuccess : (list : Array<any>) => void,
	onFail : (msg : string) => void
) {
	const baseUrl = getApiBaseUrl()
	uni.request({
		url: baseUrl + '/api/invites/received',
		method: 'GET',
		success: (res) => {
			if (res.statusCode >= 200 && res.statusCode < 300) {
				onSuccess(asList(res.data))
				return
			}
			onFail('获取邀请失败: HTTP ' + res.statusCode)
		},
		fail: (err) => {
			onFail(withUrl(err, baseUrl + '/api/invites/received'))
		}
	})
}

export function getHostViewInvites(
	onSuccess : (list : Array<any>) => void,
	onFail : (msg : string) => void
) {
	const baseUrl = getApiBaseUrl()
	uni.request({
		url: baseUrl + '/api/invites/host-view',
		method: 'GET',
		success: (res) => {
			if (res.statusCode >= 200 && res.statusCode < 300) {
				onSuccess(asList(res.data))
				return
