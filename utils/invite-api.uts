export function respondToInvite(
	inviteId : any,
	status : string,
	replyNote : string,
	onSuccess : () => void,
	onFail : (msg : string) => void
) {
	const baseUrl = getApiBaseUrl()
	uni.request({
		url: baseUrl + '/api/invites/respond',
		method: 'POST',
		header: {
			'Content-Type': 'application/json'
		},
		data: {
			inviteId,
			status,
			replyNote
		},
		success: (res) => {
			if (res.statusCode >= 200 && res.statusCode < 300) {
				onSuccess()
				return
			}
			onFail('提交响应失败: HTTP ' + res.statusCode)
		},
		fail: (err) => {
			onFail(withUrl(err, baseUrl + '/api/invites/respond'))
		}
	})
}

export function createActivity(
	payload : any,
	onSuccess : (activityId : string) => void,
	onFail : (msg : string) => void
) {
	const baseUrl = getApiBaseUrl()
	uni.request({
		url: baseUrl + '/api/activities/create',
		method: 'POST',
		header: {
			'Content-Type': 'application/json'
		},
		data: payload,
		success: (res) => {
			if (res.statusCode >= 200 && res.statusCode < 300) {
				const data : any = res.data
				const activityId = data != null ? data.activityId as string : ''
				if (activityId != null && activityId.length > 0) {
					onSuccess(activityId)
					return
				}
				onFail('创建活动失败: 缺少activityId')
				return
			}
			onFail('创建活动失败: HTTP ' + res.statusCode)
		},
		fail: (err) => {
			onFail(withUrl(err, baseUrl + '/api/activities/create'))
		}
	})
}

export function getActivityDetail(
	activityId : string,
	onSuccess : (data : any) => void,
	onFail : (msg : string) => void
) {
	const baseUrl = getApiBaseUrl()
	uni.request({
		url: baseUrl + '/api/activities/detail?activityId=' + encodeURIComponent(activityId),
		method: 'GET',
		success: (res) => {
			if (res.statusCode >= 200 && res.statusCode < 300) {
				onSuccess(res.data)
				return
			}
			onFail('获取活动详情失败: HTTP ' + res.statusCode)
		},
		fail: (err) => {
			onFail(withUrl(err, baseUrl + '/api/activities/detail'))
		}
	})
}

