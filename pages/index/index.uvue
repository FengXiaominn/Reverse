	color: #ffffff;
	font-size: 13px;
}

.section-card {
	margin: 12px 12px 0;
	padding: 14px;
	border-radius: 12px;
	background-color: #ffffff;
}

.section-title {
	font-size: 16px;
	font-weight: 600;
	color: #1f2a44;
}

.section-note {
	margin-top: 6px;
	font-size: 12px;
	color: #7c88a3;
}

.loading-text {
	display: block;
	margin-top: 10px;
	font-size: 13px;
	color: #6a7897;
}

