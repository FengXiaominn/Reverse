	margin-top: 10px;
}

.option-item {
	padding: 10px;
	border-radius: 8px;
	margin-bottom: 8px;
	background-color: #f4f6fb;
}

.option-item-active {
	background-color: #dbe6ff;
}

.option-text {
	font-size: 14px;
	color: #2b3752;
}

.switch-row {
	margin-top: 12px;
	flex-direction: row;
	justify-content: space-between;
}

.switch-item {
	width: 48%;
	padding: 10px 0;
	border-radius: 10px;
	background-color: #eef2ff;
	align-items: center;
}

.switch-item-active {
	background-color: #2f6bff;
}

.switch-text {
	font-size: 15px;
	color: #22314f;
}

.switch-text-active {
	color: #ffffff;
}

.form-row {
	margin-top: 12px;
}

.label {
	font-size: 13px;
	color: #5b6882;
}

.input {
	height: 38px;
	margin-top: 6px;
	padding: 0 10px;
	border-radius: 8px;
	background-color: #f4f6fb;
}

.picker-box {
	height: 38px;
	margin-top: 6px;
	padding: 0 10px;
	border-radius: 8px;
	background-color: #f4f6fb;
	justify-content: center;
}

.picker-text {
	font-size: 14px;
	color: #2c3a56;
}

.textarea {
	height: 72px;
	margin-top: 6px;
	padding: 8px 10px;
	border-radius: 8px;
	background-color: #f4f6fb;
}

.submit-btn {
	margin-top: 16px;
	height: 40px;
	line-height: 40px;
	border-radius: 8px;
	background-color: #2f6bff;
	color: #ffffff;
	font-size: 15px;
}

.result {
	margin-bottom: 20px;
	background-color: #f8fbff;
}

.result-line {
	display: block;
	margin-top: 8px;
	font-size: 14px;
	color: #2c3a56;
}

.host-board {
	margin-bottom: 20px;
}

.notice-board {
	margin-bottom: 20px;
}

.host-item {
	margin-top: 10px;
	padding: 10px;
	border-radius: 10px;
	background-color: #f8fbff;
}

.host-top {
	flex-direction: row;
	justify-content: space-between;
	align-items: center;
}

.host-title {
	font-size: 14px;
	color: #1f2a44;
}

.host-status {
	font-size: 12px;
	padding: 2px 8px;
	border-radius: 10px;
}

.status-pending {
	background-color: #ffecc7;
	color: #9a6a00;
}

.status-accepted {
	background-color: #d7f6df;
	color: #177245;
}

.status-rejected {
	background-color: #ffe1e1;
	color: #9f2323;
}

.host-line {
	display: block;
	margin-top: 6px;
	font-size: 13px;
	color: #43506b;
}
</style>
