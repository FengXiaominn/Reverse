<template>
	<scroll-view class="page" scroll-y="true">
		<view class="section-card">
			<text class="section-title">网络最小测试</text>
			<text class="line">Base URL：{{ baseUrl }}</text>
			<text class="line">AppID：{{ appId }}</text>
			<text class="line">Env：{{ envVersion }}</text>
			<text class="line">最后结果：{{ lastResult.length > 0 ? lastResult : '未测试' }}</text>
			<view class="btn-row">
				<button class="btn" @click="testPing">测 /api/ping</button>
				<button class="btn" @click="testPingByWx">测 wx.request</button>
			</view>
			<view class="btn-row">
				<button class="btn" @click="testInvites">测 /api/invites/received</button>
				<button class="btn" @click="testCreate">测 POST /api/activities/create</button>
			</view>
			<view class="btn-row">
				<button class="btn" @click="testWechatOfficial">测微信官方域名</button>
			</view>
			<view class="btn-row">
				<button class="btn btn-muted" @click="clearLogs">清空日志</button>
			</view>
		</view>

		<view class="section-card">
			<text class="section-title">请求日志（最新在上）</text>
			<text class="line" v-if="logs.length == 0">暂无日志</text>
			<text class="log-line" v-for="(item, index) in logs" :key="index">{{ item }}</text>
		</view>
	</scroll-view>
</template>

<script setup lang="uts">
import { getApiBaseUrl } from '../../utils/invite-api.uts'

const baseUrl = ref(getApiBaseUrl())
const lastResult = ref('')
const logs = ref<Array<string>>([])
const appId = ref('unknown')
const envVersion = ref('unknown')

function loadRuntimeInfo() {
	// #ifdef MP-WEIXIN
	const info : any = wx.getAccountInfoSync()
	if (info != null && info.miniProgram != null) {
		if (info.miniProgram.appId != null) {
			appId.value = info.miniProgram.appId
		}
		if (info.miniProgram.envVersion != null) {
			envVersion.value = info.miniProgram.envVersion
		}
	}
	// #endif
}

onMounted(() => {
	loadRuntimeInfo()
})

function stamp() : string {
	const d = new Date()
	const h = `${d.getHours()}`.padStart(2, '0')
	const m = `${d.getMinutes()}`.padStart(2, '0')
	const s = `${d.getSeconds()}`.padStart(2, '0')
	return `${h}:${m}:${s}`
}

function pushLog(msg : string) {
	logs.value.unshift(`[${stamp()}] ${msg}`)
}

function clearLogs() {
	logs.value = []
	lastResult.value = ''
}

function testPing() {
	runRequest('/api/ping', 'GET', null)
}

function testInvites() {
	runRequest('/api/invites/received', 'GET', null)
}

function testPingByWx() {
	const url = baseUrl.value + '/api/ping'
	pushLog(`WX_REQ GET ${url}`)
	// #ifdef MP-WEIXIN
	wx.request({
		url,
		method: 'GET',
		success: (res : any) => {
			const body = JSON.stringify(res.data)
			lastResult.value = `WX_SUCCESS HTTP ${res.statusCode}`
			pushLog(`WX_SUCCESS HTTP ${res.statusCode} ${body}`)
		},
		fail: (err : any) => {
			let raw = 'unknown'
			if (err != null && err.errMsg != null) {
				raw = err.errMsg
			}
			const errno = err != null && err.errno != null ? `${err.errno}` : 'none'
			const errCode = err != null && err.errCode != null ? `${err.errCode}` : 'none'
			const cronet = err != null && err.cronet_error_code != null ? `${err.cronet_error_code}` : 'none'
			const detail = JSON.stringify(err)
			lastResult.value = `WX_FAIL ${raw}`
			pushLog(`WX_FAIL ${raw}`)
			pushLog(`WX_FAIL_CODE errno=${errno} errCode=${errCode} cronet=${cronet}`)
			pushLog(`WX_FAIL_DETAIL ${detail}`)
		}
	})
	// #endif
}

function testCreate() {
	runRequest('/api/activities/create', 'POST', {
		organizer: 'nettest',
		court: '鹏迈',
		date: '2026-03-26',
		time: '20:00',
		people: '4',
		hasDinner: false,
		note: 'nettest'
	})
}

function testWechatOfficial() {
	const url = 'https://api.weixin.qq.com/cgi-bin/getcallbackip'
	pushLog(`WX_OFFICIAL_REQ GET ${url}`)
	// #ifdef MP-WEIXIN
	wx.request({
		url,
		method: 'GET',
		success: (res : any) => {
			const body = JSON.stringify(res.data)
			lastResult.value = `WX_OFFICIAL_SUCCESS HTTP ${res.statusCode}`
			pushLog(`WX_OFFICIAL_SUCCESS HTTP ${res.statusCode} ${body}`)
		},
		fail: (err : any) => {
			let raw = 'unknown'
			if (err != null && err.errMsg != null) {
				raw = err.errMsg
			}
			const detail = JSON.stringify(err)
			lastResult.value = `WX_OFFICIAL_FAIL ${raw}`
			pushLog(`WX_OFFICIAL_FAIL ${raw}`)
			pushLog(`WX_OFFICIAL_FAIL_DETAIL ${detail}`)
		}
	})
	// #endif
}

function runRequest(path : string, method : string, data : any) {
	const url = baseUrl.value + path
	pushLog(`REQ ${method} ${url}`)
	uni.request({
		url,
		method,
		header: {
			'Content-Type': 'application/json'
		},
		data,
		success: (res) => {
			const body = JSON.stringify(res.data)
			lastResult.value = `SUCCESS HTTP ${res.statusCode}`
			pushLog(`SUCCESS HTTP ${res.statusCode} ${body}`)
		},
		fail: (err) => {
			let raw = 'unknown'
			if (err != null && err.errMsg != null) {
				raw = err.errMsg
			}
			const detail = JSON.stringify(err)
			lastResult.value = `FAIL ${raw}`
			pushLog(`FAIL ${raw}`)
			pushLog(`FAIL_DETAIL ${detail}`)
		}
	})
}
</script>

<style>
.page {
	height: 100vh;
	background: linear-gradient(180deg, #f6f8ff 0%, #edf2ff 100%);
}

.section-card {
	margin: 12px;
	padding: 14px;
	border-radius: 12px;
	background-color: #ffffff;
}

.section-title {
	font-size: 16px;
	font-weight: 600;
	color: #1f2a44;
}

.line {
	display: block;
	margin-top: 8px;
	font-size: 13px;
	color: #43506b;
	word-break: break-all;
}

.btn-row {
	margin-top: 10px;
	flex-direction: row;
	justify-content: space-between;
}

.btn {
	width: 49%;
	height: 38px;
	line-height: 38px;
	border-radius: 8px;
	background-color: #2f6bff;
	color: #ffffff;
	font-size: 13px;
}

.btn-muted {
	background-color: #a9b4cd;
}

.log-line {
	display: block;
	margin-top: 8px;
	padding: 8px;
	border-radius: 8px;
	background-color: #f4f6fb;
	font-size: 12px;
	color: #2f3b55;
	word-break: break-all;
}
</style>
